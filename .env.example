# ============================================================
# 根目录环境变量模板，主要给 scripts/preload_model.py 和全局参考使用。
# 三个服务运行时读取的是各自子项目目录下的 .env：
#   qdrant-demo/.env
#   weaviate-demo/.env
#   milvus-demo/.env
#
# 使用方法：如需根目录 .env，可复制本文件后按需修改
#     cp .env.example .env
# ============================================================

# ---- 选用的嵌入模型 ----
# 英文/多语言场景（384 维，约 90MB）：
#     sentence-transformers/all-MiniLM-L6-v2
# 中文场景（512 维，约 95MB）：
#     BAAI/bge-small-zh-v1.5
#
# 注意：换模型后，向量维度会变，必须重建集合（见各子项目 README 的"切换模型"章节）
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- 模型加载方式 ----
# 默认只从项目根目录 ./models/ 加载，服务运行时不访问 HuggingFace
# 如确需运行时联网下载/补全模型，改为 0
EMBEDDING_LOCAL_ONLY=1
