# semantic-sandbox root environment template
#
# 使用方式：
# 1. cp .env.example .env
# 2. 至少替换 POSTGRES_PASSWORD、DATABASE_URL、API_KEY、WEB_PASSWORD、WEB_SESSION_SECRET
# 3. docker compose up -d
# 4. python scripts/init_postgres.py
#
# 注意：
# - 根目录 .env 同时给 Docker Compose 和本地 FastAPI 服务读取。
# - 三套 service 目录下的 .env 会覆盖根目录同名变量，适合单服务调试。
# - 本地 HTTP 调试保持 WEB_SESSION_HTTPS_ONLY=0；HTTPS 反代就绪后生产环境改为 1。

# ---- Runtime ----
# APP_ENV 仅用于区分环境：local / staging / production。
APP_ENV=local
# FastAPI 监听地址；本地只给自己访问可改为 127.0.0.1，服务器部署通常用 0.0.0.0。
APP_HOST=0.0.0.0
# 默认 Web UI 端口。三套服务一起跑时建议分别用 8888 / 8889 / 8890。
APP_PORT=8888

# ---- Docker Compose ----
# 默认同时启动 PostgreSQL + Qdrant + Weaviate + Milvus。
# 只想启动一个向量后端时改成：
#   COMPOSE_PROFILES=qdrant
#   COMPOSE_PROFILES=weaviate
#   COMPOSE_PROFILES=milvus
COMPOSE_PROFILES=qdrant,weaviate,milvus

# ---- REST API Auth ----
# 保护 /api/* 写入、搜索、文档管理、重建、导入任务等接口。
# /health、/api/count、/api/model/status、/api/samples/{lang} 保持公开，方便探活和页面基础读取。
AUTH_ENABLED=1
# 生产必须替换为长随机值；不要使用默认值。
API_KEY=change_me_to_a_long_random_secret
# 客户端请求头：curl -H "X-API-Key: $API_KEY" http://localhost:8888/api/documents
API_KEY_HEADER=X-API-Key

# ---- Web UI Auth ----
# 保护浏览器页面、Swagger UI、/openapi.json 和 HTML 表单提交。
# Web 登录态不替代 REST API Key；程序调用 /api/* 仍应带 X-API-Key。
WEB_AUTH_ENABLED=1
WEB_USERNAME=admin
# 生产必须替换；建议至少 16 位以上，和 API_KEY 不要相同。
WEB_PASSWORD=change_me_to_a_strong_password
# 签名 Cookie 密钥，生产必须替换为 32 字节以上随机字符串。
WEB_SESSION_SECRET=change_me_to_a_long_random_session_secret
# 三个 Web UI 如果部署在同一域名不同端口，可以共用 Cookie 名和 secret。
# 如果三个服务分别配置不同 secret，建议给每个服务使用不同 Cookie 名。
WEB_SESSION_COOKIE=semantic_sandbox_session
# 会话有效期，默认 86400 秒，即 1 天。
WEB_SESSION_MAX_AGE_SECONDS=86400
# 只有 HTTPS 反向代理已经就绪时才设为 1；本地 http://localhost 调试必须为 0。
WEB_SESSION_HTTPS_ONLY=0

# ---- PostgreSQL Metadata Store ----
# postgres：使用 PostgreSQL 作为业务元数据主库。
# json：退回本地 JSON 文件，仅适合临时开发，不建议上线。
METADATA_STORE=postgres
POSTGRES_DB=semantic_sandbox
POSTGRES_USER=sandbox
# Docker Compose 内部 PostgreSQL 密码；生产必须替换。
POSTGRES_PASSWORD=sandbox_password
# PostgreSQL 映射到宿主机的端口。本机已有 5432 时可改成 15432。
POSTGRES_PORT=5432
# 本地 FastAPI / 脚本连接 PostgreSQL 的 DSN。
# 如果改了 POSTGRES_PASSWORD 或 POSTGRES_PORT，这里必须同步修改。
DATABASE_URL=postgresql://sandbox:sandbox_password@localhost:5432/semantic_sandbox
# 常驻连接池大小。单机小流量 5 足够；并发增加后再调大。
DB_POOL_SIZE=5
# 高峰期允许额外创建的连接数；总连接上限约为 DB_POOL_SIZE + DB_MAX_OVERFLOW。
DB_MAX_OVERFLOW=10
# 从连接池等待连接的秒数。
DB_POOL_TIMEOUT=30
# 单条 SQL 超时毫秒数，避免慢查询拖死 API。
DB_STATEMENT_TIMEOUT_MS=5000

# ---- Vector Backend ----
# 当前 FastAPI 服务写入哪个向量后端。
# 同一进程只写一个后端；三套 Web UI 分别由各自 service/.env.example 指定。
VECTOR_BACKEND=qdrant
# collection / class / collection_name。Weaviate v4 要求首字母大写，见 weaviate-service/.env.example。
COLLECTION_NAME=sandbox_docs

# Qdrant：Docker 容器内部端口是 6333/6334；这里配置的是宿主机映射端口。
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Weaviate：HTTP 用于 REST / SDK，gRPC 用于 v4 client。
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# Milvus：MILVUS_URI 给 Python SDK 使用；MILVUS_PORT 是 Docker 宿主机端口。
MILVUS_URI=http://localhost:19530
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
# MinIO / Attu 是 Milvus standalone 的辅助服务。
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
ATTU_PORT=8000

# ---- Embedding Model ----
# 默认英文小模型，384 维。中文可改为 BAAI/bge-small-zh-v1.5，512 维。
# 切换模型后需要重建向量索引。
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# 1：只从 ./models 加载，服务运行时不访问 HuggingFace；生产建议保持 1。
# 0：允许运行时联网下载模型，仅适合本地调试。
EMBEDDING_LOCAL_ONLY=1

# ---- Seed Data ----
# 命令行 python -m src.ingest 默认读取的数据文件。
# 该路径相对 service 目录，所以根 .env 使用 ../data/sample_en.json。
DATA_FILE=../data/sample_en.json
