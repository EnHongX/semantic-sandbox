# ============================================================
# 公共环境变量（三个子项目都会读这个）
# 使用方法：复制本文件为 .env，然后按需修改
#     cp .env.example .env
# ============================================================

# ---- 选用的嵌入模型 ----
# 英文/多语言场景（384 维，约 90MB）：
#     sentence-transformers/all-MiniLM-L6-v2
# 中文场景（512 维，约 95MB）：
#     BAAI/bge-small-zh-v1.5
#
# 注意：换模型后，向量维度会变，必须重建集合（见各子项目 README 的"切换模型"章节）
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- 可选：HuggingFace 缓存目录 ----
# 不设置的话默认在 ~/.cache/huggingface
# 如果你想把模型缓存放到项目内，可以改为 ./models
# HF_HOME=./models
