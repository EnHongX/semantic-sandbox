# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- 虚拟环境（重要：不要提交） ----
venv/
.venv/
env/
ENV/

# ---- 依赖构建产物 ----
build/
dist/
*.egg-info/
.eggs/

# ---- 环境变量（含 API Key，禁止提交） ----
.env
.env.local
*.env

# ---- 编辑器 / 系统 ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ---- 模型缓存 ----
# 本项目默认把模型下载到 ./models/，跟项目目录走（不是系统级 ~/.cache）
# 但模型本身不能进 Git（~185MB，超 GitHub 单文件 100MB 限制），必须忽略
models/

# ---- 各向量库的数据卷（docker-compose 挂载在子项目内时）----
**/volumes/
**/milvus_data/
**/weaviate_data/
**/qdrant_data/

# ---- 日志 ----
*.log
logs/

# ---- 用户通过 Web UI 写入的数据（本地备份，不进仓库）----
data/user_data.json
data/documents.json
data/search_logs.jsonl
data/app_errors.jsonl
data/import_reports/
