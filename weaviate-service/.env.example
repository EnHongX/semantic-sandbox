# weaviate-service runtime environment template
#
# 使用方式：
# - 单独运行 Weaviate 服务时：cp weaviate-service/.env.example weaviate-service/.env
# - 服务启动会先读取根目录 ../.env，再读取本文件；本文件同名变量优先级更高。
# - 如果三套服务共用根 .env，不需要为每个 service 单独创建 .env。

# ---- 嵌入模型 ----
# 英文: sentence-transformers/all-MiniLM-L6-v2  (384 维)
# 中文: BAAI/bge-small-zh-v1.5                   (512 维)
# 切换模型后必须重建向量索引。
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# 1 表示只从项目根目录 ../models/ 加载，服务运行时不访问 HuggingFace。
EMBEDDING_LOCAL_ONLY=1

# ---- Weaviate 连接 ----
# 如果根 .env 修改了 WEAVIATE_HTTP_PORT / WEAVIATE_GRPC_PORT，这里也要同步。
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# ---- REST API 鉴权 ----
# 保护 /api/* 写入、搜索、文档管理、重建、导入任务等接口。
AUTH_ENABLED=1
API_KEY=change_me_to_a_long_random_secret
API_KEY_HEADER=X-API-Key

# ---- Web UI 登录态 ----
# 保护 /、/ingest、/documents、/health/panel、/logs、/docs、/openapi.json。
WEB_AUTH_ENABLED=1
WEB_USERNAME=admin
WEB_PASSWORD=change_me_to_a_strong_password
WEB_SESSION_SECRET=change_me_to_a_long_random_session_secret
WEB_SESSION_COOKIE=semantic_sandbox_session
WEB_SESSION_MAX_AGE_SECONDS=86400
# 本地 HTTP 调试保持 0；HTTPS 反向代理就绪后生产环境改为 1。
WEB_SESSION_HTTPS_ONLY=0

# ---- PostgreSQL 元数据主库 ----
METADATA_STORE=postgres
VECTOR_BACKEND=weaviate
# 如果根 .env 修改了 POSTGRES_PORT 或 POSTGRES_PASSWORD，这里也要同步。
DATABASE_URL=postgresql://sandbox:sandbox_password@localhost:5432/semantic_sandbox
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_STATEMENT_TIMEOUT_MS=5000

# ---- 业务配置 ----
# Weaviate v4 的 collection 名必须首字母大写。
COLLECTION_NAME=SandboxDocs

# 默认加载的数据文件，相对本子项目根目录。
DATA_FILE=../data/sample_en.json
